# Copy this file to config/windows.env before running bootstrap/windows.ps1.

DOTFILES_GIT_USER_NAME='Your Name'
DOTFILES_GIT_USER_EMAIL='you@example.com'
DOTFILES_WINDOWS_ENABLE_WSL=0

# Optional overrides:
# DOTFILES_DATA_HOME="$HOME/.local/share/dotfiles"
#
# Notes:
# - Windows native setup uses winget as the package manager.
# - Enable WSL when you want to run bootstrap/linux.sh inside the distro for Unix-style CLI tools.
