# Copy this file to testenv/parallels/config.env and fill in each value.
# The "template" values can point to a Parallels template or a stopped golden VM.

DOTFILES_PARALLELS_MACOS_TEMPLATE_NAME='dotfiles-macos-golden'
DOTFILES_PARALLELS_WINDOWS_TEMPLATE_NAME='dotfiles-windows-golden'

DOTFILES_PARALLELS_MACOS_VM_NAME='dotfiles-macos'
DOTFILES_PARALLELS_WINDOWS_VM_NAME='dotfiles-windows'

DOTFILES_PARALLELS_MACOS_REPO_PATH='/Users/<vm-user>/dotfiles'
DOTFILES_PARALLELS_WINDOWS_REPO_PATH='C:\Users\<vm-user>\dotfiles'
