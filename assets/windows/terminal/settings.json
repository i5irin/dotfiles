{
  "$schema": "https://aka.ms/terminal-profiles-schema",
  "copyFormatting": "none",
  "copyOnSelect": false,
  "profiles": {
    "defaults": {
      "colorScheme": "Catppuccin Frappe",
      "fontFace": "Fira Code",
      "fontSize": 12,
      "historySize": 50000,
      "padding": "10, 10, 10, 10",
      "scrollbarState": "visible",
      "snapOnInput": true
    }
  },
  "schemes": [
    {
      "name": "Catppuccin Frappe",
      "background": "#303446",
      "black": "#51576d",
      "blue": "#8caaee",
      "brightBlack": "#626880",
      "brightBlue": "#7b9ef0",
      "brightCyan": "#5abfb5",
      "brightGreen": "#8ec772",
      "brightPurple": "#f2a4db",
      "brightRed": "#e67172",
      "brightWhite": "#b5bfe2",
      "brightYellow": "#d9ba73",
      "cursorColor": "#f2d5cf",
      "cyan": "#81c8be",
      "foreground": "#c6d0f5",
      "green": "#a6d189",
      "purple": "#f4b8e4",
      "red": "#e78284",
      "selectionBackground": "#626880",
      "white": "#a5adce",
      "yellow": "#e5c890"
    }
  ]
}
